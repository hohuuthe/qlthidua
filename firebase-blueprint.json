{
  "entities": {
    "ClassInfo": {
      "title": "Chi đoàn",
      "description": "Thông tin chi tiết về một chi đoàn",
      "type": "object",
      "properties": {
        "chiDoan": { "type": "string", "description": "Tên chi đoàn" },
        "biThu": { "type": "string", "description": "Họ tên bí thư" },
        "phoBiThu": { "type": "string", "description": "Họ tên phó bí thư" },
        "uyVien": { "type": "string", "description": "Họ tên ủy viên" },
        "lopTruong": { "type": "string", "description": "Họ tên lớp trưởng" },
        "sdt": { "type": "string", "description": "Số điện thoại liên hệ" },
        "tongSoThanhVien": { "type": "number", "description": "Tổng số thành viên" },
        "doanVien": { "type": "number", "description": "Số lượng đoàn viên" },
        "thanhNien": { "type": "number", "description": "Số lượng thanh niên" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Thời gian cập nhật cuối" }
      },
      "required": ["chiDoan"]
    }
  },
  "firestore": {
    "/classes/{classId}": {
      "schema": "ClassInfo",
      "description": "Danh sách các chi đoàn trong hệ thống"
    }
  }
}
