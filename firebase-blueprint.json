{
  "entities": {
    "QlChiDoan": {
      "title": "Chi đoàn",
      "description": "Thông tin chi tiết về quản lý chi đoàn",
      "type": "object",
      "properties": {
        "tenchidoan": { "type": "string", "description": "Tên chi đoàn" },
        "doanvien": { "type": "number", "description": "Số lượng đoàn viên" },
        "thanhnien": { "type": "number", "description": "Số lượng thanh niên" },
        "tongso": { "type": "number", "description": "Tổng số thành viên" },
        "phonghoc": { "type": "string", "description": "Phòng học" },
        "bithu": { "type": "string", "description": "Bí thư" },
        "thongtinthem": { "type": "string", "description": "Thông tin thêm" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Thời gian cập nhật cuối" }
      },
      "required": ["tenchidoan"]
    },
    "TaiKhoan": {
      "title": "Tài khoản",
      "description": "Thông tin tài khoản người dùng",
      "type": "object",
      "properties": {
        "username": { "type": "string", "description": "Tên đăng nhập" },
        "password": { "type": "string", "description": "Mật khẩu" },
        "fullName": { "type": "string", "description": "Họ và tên" },
        "role": { "type": "string", "description": "Đối tượng (Admin, BTV, BCH, BT, DV)" },
        "chiDoan": { "type": "string", "description": "Tên chi đoàn quản lý" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Thời gian cập nhật cuối" }
      },
      "required": ["username", "password", "fullName", "role"]
    }
  },
  "firestore": {
    "/qlchidoan/{id}": {
      "schema": "QlChiDoan",
      "description": "Danh sách quản lý chi đoàn"
    },
    "/taikhoan/{id}": {
      "schema": "TaiKhoan",
      "description": "Danh sách tài khoản"
    }
  }
}
