rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: classes
    // Document ID: auto-generated or classId
    // Fields:
    //   - chiDoan: string (required, 1-100 chars)
    //   - doanVien: number (positive)
    //   - thanhNien: number (positive)
    //   - tongSo: number (positive)
    //   - phongHoc: string (0-50 chars)
    //   - updatedAt: timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "huuthe87@gmail.com" && request.auth.token.email_verified == true);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidClass(data) {
      return hasOnlyAllowedFields(['chiDoan', 'doanVien', 'thanhNien', 'tongSo', 'phongHoc', 'updatedAt']) &&
             data.chiDoan is string && data.chiDoan.size() > 0 && data.chiDoan.size() <= 100 &&
             (!('doanVien' in data) || (data.doanVien is number && data.doanVien >= 0)) &&
             (!('thanhNien' in data) || (data.thanhNien is number && data.thanhNien >= 0)) &&
             (!('tongSo' in data) || (data.tongSo is number && data.tongSo >= 0)) &&
             (!('phongHoc' in data) || (data.phongHoc is string && data.phongHoc.size() <= 50));
    }

    // Collection: members
    // Document ID: auto-generated or memberId
    // Fields:
    //   - chiDoan: string (required, 1-100 chars)
    //   - doanVien: number (positive)
    //   - thanhNien: number (positive)
    //   - tongSo: number (positive)
    //   - phongHoc: string (0-50 chars)
    //   - biThu: string (0-100 chars)
    //   - thongTinThem: string (0-500 chars)
    //   - updatedAt: timestamp
    //
    // ===============================================================

    function isValidMember(data) {
      return hasOnlyAllowedFields(['chiDoan', 'doanVien', 'thanhNien', 'tongSo', 'phongHoc', 'biThu', 'thongTinThem', 'updatedAt']) &&
             data.chiDoan is string && data.chiDoan.size() > 0 && data.chiDoan.size() <= 100 &&
             (!('doanVien' in data) || (data.doanVien is number && data.doanVien >= 0)) &&
             (!('thanhNien' in data) || (data.thanhNien is number && data.thanhNien >= 0)) &&
             (!('tongSo' in data) || (data.tongSo is number && data.tongSo >= 0)) &&
             (!('phongHoc' in data) || (data.phongHoc is string && data.phongHoc.size() <= 50)) &&
             (!('biThu' in data) || (data.biThu is string && data.biThu.size() <= 100)) &&
             (!('thongTinThem' in data) || (data.thongTinThem is string && data.thongTinThem.size() <= 500));
    }

    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidClass(request.resource.data);
      allow update: if isAdmin() && isValidClass(request.resource.data);
      allow delete: if isAdmin();
    }

    match /members/{memberId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidMember(request.resource.data);
      allow update: if isAdmin() && isValidMember(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
