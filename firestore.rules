rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: qlchidoan
    // Document ID: auto-generated or id
    // Fields:
    //   - tenchidoan: string (required, 1-100 chars)
    //   - doanvien: number (positive)
    //   - thanhnien: number (positive)
    //   - tongso: number (positive)
    //   - phonghoc: string (0-50 chars)
    //   - bithu: string (0-100 chars)
    //   - thongtinthem: string (0-500 chars)
    //   - updatedAt: timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "huuthe87@gmail.com" && request.auth.token.email_verified == true);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidQlChiDoan(data) {
      return hasOnlyAllowedFields(['tenchidoan', 'doanvien', 'thanhnien', 'tongso', 'phonghoc', 'bithu', 'thongtinthem', 'updatedAt']) &&
             data.tenchidoan is string && data.tenchidoan.size() > 0 && data.tenchidoan.size() <= 100 &&
             (!('doanvien' in data) || (data.doanvien is number && data.doanvien >= 0)) &&
             (!('thanhnien' in data) || (data.thanhnien is number && data.thanhnien >= 0)) &&
             (!('tongso' in data) || (data.tongso is number && data.tongso >= 0)) &&
             (!('phonghoc' in data) || (data.phonghoc is string && data.phonghoc.size() <= 50)) &&
             (!('bithu' in data) || (data.bithu is string && data.bithu.size() <= 100)) &&
             (!('thongtinthem' in data) || (data.thongtinthem is string && data.thongtinthem.size() <= 500));
    }

    function isValidTaiKhoan(data) {
      return hasOnlyAllowedFields(['username', 'password', 'fullName', 'role', 'chiDoan', 'updatedAt']) &&
             data.username is string && data.username.size() > 0 && data.username.size() <= 50 &&
             data.password is string && data.password.size() > 0 && data.password.size() <= 100 &&
             data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 100 &&
             data.role is string && data.role in ['Admin', 'BTV', 'BCH', 'BT', 'DV', 'User'] &&
             (!('chiDoan' in data) || (data.chiDoan is string && data.chiDoan.size() <= 100));
    }

    match /qlchidoan/{id} {
      allow read: if true;
      allow create: if isValidQlChiDoan(request.resource.data);
      allow update: if isValidQlChiDoan(request.resource.data);
      allow delete: if true;
    }

    match /taikhoan/{id} {
      allow read: if true;
      allow create: if isValidTaiKhoan(request.resource.data);
      allow update: if isValidTaiKhoan(request.resource.data);
      allow delete: if true;
    }
  }
}
